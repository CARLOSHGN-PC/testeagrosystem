      <div className="relative mt-auto pt-1.5 border-t border-amber-500/[0.06] text-[10px] text-muted-foreground">
        <span>Idade ideal: <span className="text-foreground font-semibold">~12 meses</span></span>
      </div>
    </motion.div>
