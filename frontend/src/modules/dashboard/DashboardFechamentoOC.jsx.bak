import React from "react";
import { Activity, BarChart3, Calendar, ClipboardCheck, Clock, Download, Filter, Truck, Wheat } from "lucide-react";
import {
  Bar,
  BarChart,
  CartesianGrid,
  Cell,
  ComposedChart,
  LabelList,
  Legend,
  Line,
  Pie,
  PieChart,
  ReferenceLine,
  ResponsiveContainer,
  Scatter,
  ScatterChart,
  Tooltip as RechartsTooltip,
  XAxis,
  YAxis,
  ZAxis,
} from "recharts";
import { Button } from "../../components/ui/button";

const fmt = (v, d = 2) =>
  new Intl.NumberFormat("pt-BR", {
    minimumFractionDigits: d,
    maximumFractionDigits: d,
  }).format(Number(v || 0));

const plus = (v, d = 1) => `${Number(v) >= 0 ? "+" : ""}${fmt(v, d)}`;

const gridStroke = "rgba(113, 136, 159, 0.075)";
const axisStroke = "rgba(113, 136, 159, 0.12)";
const axisText = "#cdd7e4";
const softText = "#9aa7b8";

function ShellCard({ children, className = "" }) {
  return (
    <div
      className={`relative overflow-hidden rounded-[6px] border border-[#1d2a38] bg-[linear-gradient(180deg,#111927_0%,#0d1623_52%,#0a1320_100%)] shadow-[inset_0_1px_0_rgba(255,255,255,.035),0_7px_18px_rgba(0,0,0,.20)] ${className}`}
    >
      <div className="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(255,255,255,.035),transparent_34%)]" />
      <div className="relative z-[1]">{children}</div>
    </div>
  );
}

function Panel({ title, subtitle, children, className = "" }) {
  return (
    <ShellCard className={className}>
      <div className="px-[14px] pt-[10px]">
        <h3 className="text-[12.5px] font-medium leading-tight tracking-[-.01em] text-[#edf3fb]">{title}</h3>
        {subtitle ? <p className="mt-[1px] text-[9.5px] font-normal text-[#6f7d91]">{subtitle}</p> : null}
      </div>
      {children}
    </ShellCard>
  );
}

function FilterSelect({ value, onChange, options = [] }) {
  return (
    <div className="flex h-11 items-center rounded-md border border-[#213248] bg-[linear-gradient(180deg,#0c1724,#081320)] px-3 text-white shadow-[inset_0_1px_0_rgba(255,255,255,.04)]">
      <select value={value} onChange={onChange} className="w-full bg-transparent text-[12px] font-normal outline-none">
        {options.map((o) => (
          <option className="text-black" key={o.value} value={o.value}>
            {o.label}
          </option>
        ))}
      </select>
    </div>
  );
}

function FilterDateInput({ value, onChange }) {
  return (
    <div className="flex h-11 items-center gap-2 rounded-md border border-[#213248] bg-[linear-gradient(180deg,#0c1724,#081320)] px-3 text-white">
      <Calendar className="h-4 w-4 text-[#9fb0c4]" />
      <input
        type="date"
        value={value || ""}
        onChange={onChange}
        className="w-full bg-transparent text-[12px] font-normal outline-none [color-scheme:dark]"
      />
    </div>
  );
}

function DarkTooltip({ active, payload, label }) {
  if (!active || !payload?.length) return null;
  return (
    <div className="rounded-md border border-white/10 bg-[#07111b]/95 px-3 py-2 shadow-2xl">
      <span className="mb-1 block text-xs font-normal text-[#dce6f5]">{label}</span>
      {payload.map((p, i) => (
        <div className="flex gap-5 text-xs font-normal" key={i}>
          <span className="text-[#aebaca]">{p.name}</span>
          <span style={{ color: p.color }}>{typeof p.value === "number" ? fmt(p.value, 2) : p.value}</span>
        </div>
      ))}
    </div>
  );
}

function Spark({ color = "#22c55e" }) {
  return (
    <svg viewBox="0 0 170 42" className="mt-2 h-8 w-full">
      <defs>
        <linearGradient id={`s${color.replace("#", "")}`} x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stopColor={color} stopOpacity=".24" />
          <stop offset="1" stopColor={color} stopOpacity="0" />
        </linearGradient>
      </defs>
      <path d="M2 31 C16 20 27 30 39 24 S62 18 77 23 S97 32 112 20 S143 12 168 15 L168 42 L2 42 Z" fill={`url(#s${color.replace("#", "")})`} />
      <path d="M2 31 C16 20 27 30 39 24 S62 18 77 23 S97 32 112 20 S143 12 168 15" fill="none" stroke={color} strokeWidth="1.8" strokeLinecap="round" />
    </svg>
  );
}

function Metric({ title, value, subtitle, icon: Icon, accent = "green", children }) {
  const c = {
    blue: ["#153961", "#3a87f5"],
    green: ["#0d452f", "#28cc77"],
    purple: ["#351654", "#a765f4"],
    amber: ["#50310b", "#ed8a18"],
    yellow: ["#4f410b", "#f0c319"],
    cyan: ["#0f4646", "#42d6cf"],
  }[accent];

  return (
    <ShellCard className="min-h-[122px]">
      <div className="p-[14px]">
        <div className="flex gap-3">
          <div
            className="flex h-[35px] w-[35px] shrink-0 items-center justify-center rounded-[8px] border shadow-[inset_0_1px_0_rgba(255,255,255,.10)]"
            style={{ background: c[0], borderColor: c[0], color: c[1] }}
          >
            <Icon className="h-5 w-5" />
          </div>
          <div className="min-w-0 flex-1">
            <p className="text-[11px] font-normal uppercase tracking-[.01em] text-[#d7e0eb]">{title}</p>
            {value ? <div className="mt-2 text-[23px] font-normal leading-none tracking-[-.03em] text-white">{value}</div> : null}
            {subtitle ? <div className="mt-2 text-[11px] font-normal text-[#9faabb]">{subtitle}</div> : null}
          </div>
        </div>
        {children}
      </div>
    </ShellCard>
  );
}

