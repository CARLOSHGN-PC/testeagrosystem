function Status({ status }) {
  const m = {
    Excelente: "bg-[#0f2e1c] text-[#3dcc78]",
    Bom: "bg-[#122614] text-[#6bcf90]",
    Neutro: "bg-[#1c1f2c] text-[#8492b4]",
    Atenção: "bg-[#2c1f06] text-[#e6a020]",
    Crítico: "bg-[#2c0f0f] text-[#e05252]",
  };
  return <span className={`mx-auto block w-[76px] rounded-[3px] py-[2px] text-center text-[9.5px] font-medium ${m[status]}`}>{status}</span>;
}

function HeatCell({ children, tone }) {
  const cls =
    tone === "g"
      ? "bg-[linear-gradient(90deg,rgba(22,120,60,.58),rgba(34,150,74,.62))] text-[#64f09a]"
      : tone === "y"
        ? "bg-[linear-gradient(90deg,rgba(180,140,20,.45),rgba(202,153,28,.52))] text-[#fde047]"
        : "bg-[linear-gradient(90deg,rgba(160,35,35,.58),rgba(190,48,43,.62))] text-[#ff7b7b]";
  return <td className={`${cls} border-b border-r border-[#17212e] px-2 py-[5px] text-center text-[10.5px] font-medium`}>{children}</td>;
}

function GapLabel({ x, y, value }) {
  if (x == null || y == null) return null;
  const boxY = y + 9;
  const textY = y + 21;
  return (
    <g>
      <rect
        x={x - 22}
        y={boxY}
        width="44"
        height="17"
        rx="3.5"
        fill="rgba(105,75,17,.78)"
        stroke="rgba(235,178,45,.22)"
        strokeWidth="0.7"
      />
      <text x={x} y={textY} textAnchor="middle" fill="#ffd23d" fontSize="9" fontWeight="400">
        {plus(value, 1)}%
      </text>
    </g>
  );
}


export default function DashboardFechamentoOC({ safra, setSafra, fazenda, setFazenda, dataInicio, setDataInicio, dataFim, setDataFim, options = {} }) {
  const heat = rows.slice(0, 6).map((r, i) => ({
    ...r,
    atr: [140.8, 136.5, 132.4, 128.7, 125.6, 118.9][i],
    tempo: [5.21, 4.98, 6.15, 7.45, 6.8, 8.9][i],
    indice: [92, 88, 80, 65, 52, 38][i],
  }));

  return (
    <div className="w-full max-w-none space-y-[7px] text-white [font-family:Inter,system-ui,-apple-system,BlinkMacSystemFont,Segoe_UI,sans-serif]">
      <div className="grid w-full gap-2 md:grid-cols-2 xl:grid-cols-[130px_minmax(135px,1fr)_minmax(135px,1fr)_minmax(135px,1fr)_minmax(135px,1fr)_minmax(135px,1fr)_minmax(135px,1fr)_74px_88px]">
        <div className="flex h-11 items-center gap-2 rounded-md border border-[#213248] bg-[#091522] px-3 text-[12px] font-normal uppercase tracking-[.16em] text-[#b9c9e7]">
          <Filter className="h-4 w-4" />Filtros
        </div>
        <FilterSelect value={safra} onChange={(e) => setSafra?.(e.target.value)} options={[{ value: "todas", label: "Safra 26/27" }, ...(options.safras || []).map((x) => ({ value: x, label: x }))]} />
        <FilterSelect value={fazenda} onChange={(e) => setFazenda?.(e.target.value)} options={[{ value: "todas", label: "Todas Fazendas" }, ...rows.map((r) => ({ value: r.fazenda, label: r.fazenda }))]} />
        <FilterDateInput value={dataInicio} onChange={(e) => setDataInicio?.(e.target.value)} />
        <FilterDateInput value={dataFim} onChange={(e) => setDataFim?.(e.target.value)} />
        <FilterSelect value="todos" onChange={() => {}} options={[{ value: "todos", label: "Todos Estágios" }]} />
        <FilterSelect value="todos" onChange={() => {}} options={[{ value: "todos", label: "Todas Situações" }]} />
        <Button variant="ghost" className="h-11 rounded-md border border-[#273a53] bg-[#0d1724] px-2 text-[12px] font-normal text-[#dbeafe]">
          <Filter className="mr-1 h-4 w-4" />Filtros
        </Button>
        <Button className="h-11 rounded-md bg-[#159957] px-2 text-[12px] font-normal text-white">
          <Download className="mr-1 h-4 w-4" />Exportar
        </Button>
      </div>

      <div className="grid w-full gap-[7px] xl:grid-cols-6">
        <Metric title="OC'S FECHADAS" value="170" subtitle="Total no período" icon={ClipboardCheck} accent="blue">
          <div className="mt-3 border-t border-white/7 pt-3 text-[12px] font-normal">
            <p className="text-[#eab63e]">Parcial: 31 (18%)</p>
            <p className="mt-2 text-[#ef4444]">Cancelada: 7 (4%)</p>
          </div>
        </Metric>
        <Metric title="ÁREA COLHIDA" value="2.410,28 ha" icon={Wheat} accent="green">
          <div className="mt-4 border-t border-white/7 pt-3 text-[12px] font-normal">
            <p className="text-[#48a9f8]">Liberada: 2.450,18 ha</p>
            <p className="mt-2 text-[#27d17c]">Aderência: 98,37%</p>
            <div className="mt-3 h-[7px] overflow-hidden rounded-full bg-[#182836]">
              <div className="h-full w-[91%] rounded-full bg-[linear-gradient(90deg,#2fd695,#1fb66e)] shadow-[0_0_12px_rgba(47,214,149,.55)]" />
            </div>
          </div>
        </Metric>
        <Metric title="TCH MÉDIO (T/HA)" value="" icon={Activity} accent="purple">
          <div className="-mt-5 grid grid-cols-2 gap-2 text-center">
            <div>
              <p className="text-[11px] text-[#9ea9bb]">Previsto</p>
              <p className="mt-1 text-[22px] font-normal text-[#47a3ff]">78,75</p>
            </div>
            <div>
              <p className="text-[11px] text-[#9ea9bb]">Real</p>
              <p className="mt-1 text-[22px] font-normal text-[#27d17c]">82,11</p>
            </div>
          </div>
          <Spark color="#a765f4" />
        </Metric>
        <Metric title="PRODUÇÃO REAL" value="204.829 t" subtitle="No período" icon={Truck} accent="amber">
          <Spark color="#ed8a18" />
        </Metric>
        <Metric title="ATR MÉDIO" value="134,40" subtitle="kg/t" icon={BarChart3} accent="yellow">
          <Spark color="#f0c319" />
        </Metric>
        <Metric title="TEMPO FECHAMENTO" value="6,48 dias" subtitle="Média por OC" icon={Clock} accent="cyan">
          <Spark color="#42d6cf" />
        </Metric>
      </div>

      <div className="grid w-full gap-[7px] xl:grid-cols-[58fr_42fr]">
        <Panel title="TCH Previsto x Real por Fazenda" subtitle="Comparativo do TCH médio (T/Ha)">
          <div className="h-[270px] px-3 pb-2">
            <ResponsiveContainer>
              <ComposedChart data={rows} margin={{ top: 18, right: 16, left: -12, bottom: 16 }}>
                <defs>
                  <linearGradient id="barBlueOC" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stopColor="#3f7fd9" /><stop offset="1" stopColor="#214f96" /></linearGradient>
                  <linearGradient id="barGreenOC" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stopColor="#31ba6d" /><stop offset="1" stopColor="#168046" /></linearGradient>
                </defs>
                <CartesianGrid stroke={gridStroke} vertical={false} />
                <XAxis dataKey="fazenda" tick={{ fill: axisText, fontSize: 9, fontWeight: 400 }} axisLine={false} tickLine={false} />
                <YAxis yAxisId="left" domain={[0, 130]} ticks={[0, 25, 50, 75, 100, 125]} tick={{ fill: softText, fontSize: 9, fontWeight: 400 }} axisLine={false} tickLine={false} label={{ value: "TCH (T/Ha)", angle: -90, fill: softText, fontSize: 9, position: "insideLeft" }} />
                <YAxis yAxisId="right" orientation="right" domain={[-20, 35]} ticks={[-20, -10, 0, 10, 20, 30]} tickFormatter={(v) => `${v}%`} tick={{ fill: softText, fontSize: 9, fontWeight: 400 }} axisLine={false} tickLine={false} label={{ value: "Gap (%)", angle: 90, fill: softText, fontSize: 9, position: "insideRight" }} />
                <Legend verticalAlign="top" iconSize={10} wrapperStyle={{ color: axisText, fontSize: 9.5, fontWeight: 400, top: -2 }} />
                <Bar yAxisId="left" dataKey="prev" name="TCH Previsto (T/Ha)" fill="url(#barBlueOC)" radius={[2, 2, 0, 0]} barSize={18}>
                  <LabelList dataKey="prev" position="top" fill="#d7dfeb" fontSize={9} fontWeight={400} formatter={(v) => fmt(v, 1)} />
                </Bar>
                <Bar yAxisId="left" dataKey="real" name="TCH Real (T/Ha)" fill="url(#barGreenOC)" radius={[2, 2, 0, 0]} barSize={18}>
                  <LabelList dataKey="real" position="top" fill="#d7dfeb" fontSize={9} fontWeight={400} formatter={(v) => fmt(v, 1)} />
                </Bar>
                <Line yAxisId="right" dataKey="gapPct" name="Gap %" stroke="#f0c030" strokeWidth={2} dot={{ r: 5, fill: "#f0c030", stroke: "#d19b15", strokeWidth: 1.4 }} activeDot={{ r: 6 }}>
                  <LabelList dataKey="gapPct" content={<GapLabel />} />
                </Line>
              </ComposedChart>
            </ResponsiveContainer>
          </div>
        </Panel>

        <Panel title="Ranking de Fazendas por Gap de TCH" subtitle="Ordenado do maior ganho para maior perda">
          <div className="px-3 pb-3">
            <table className="w-full border-collapse text-[10.5px]">
              <thead>
                <tr className="border-b border-[#1e2540] text-[#8b97aa]">
                  <th className="py-[5px] text-left font-medium">#</th><th className="text-left font-medium">Fazenda</th><th className="font-medium">TCH Previsto</th><th className="font-medium">TCH Real</th><th className="font-medium">Gap (T/Ha)</th><th className="font-medium">Gap (%)</th><th className="font-medium">Status</th>
                </tr>
              </thead>
              <tbody>
                {rows.map((r, i) => (
                  <tr key={r.fazenda} className="border-b border-[#172030] text-[#b9c5d5] hover:bg-white/[.025]">
                    <td className="py-[4px] text-[#6f7d91]">{i + 1}</td>
                    <td className="font-normal text-[#e5ebf4]">{r.fazenda}</td>
                    <td className="text-center">{fmt(r.prev, 2)}</td>
                    <td className="text-center">{fmt(r.real, 2)}</td>
                    <td className={`text-center font-medium ${r.gap >= 0 ? "text-[#3dcc78]" : "text-[#e05252]"}`}>{plus(r.gap, 2)}</td>
                    <td className={`text-center font-medium ${r.gap >= 0 ? "text-[#3dcc78]" : "text-[#e05252]"}`}>{plus(r.gapPct, 1)}%</td>
                    <td><Status status={r.status} /></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </Panel>
      </div>

      <div className="grid w-full gap-[7px] xl:grid-cols-3">
        <Panel title="Tempo de Fechamento por OC" subtitle="Dias entre abertura e encerramento">
          <div className="h-[205px] px-3 pb-2">
            <ResponsiveContainer>
              <BarChart data={tempoData} margin={{ top: 20, right: 8, left: -18, bottom: 0 }}>
                <defs><linearGradient id="barPurpleOC" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stopColor="#875bd5" /><stop offset="1" stopColor="#5432a5" /></linearGradient></defs>
                <CartesianGrid stroke={gridStroke} vertical={false} />
                <XAxis dataKey="oc" tick={{ fill: softText, fontSize: 8, fontWeight: 400 }} axisLine={false} tickLine={false} interval={0} angle={-40} textAnchor="end" height={48} />
                <YAxis tick={{ fill: softText, fontSize: 9, fontWeight: 400 }} axisLine={false} tickLine={false} label={{ value: "Dias", angle: -90, fill: softText, fontSize: 9, position: "insideLeft" }} />
                <ReferenceLine y={6.48} stroke="#e05252" strokeDasharray="5 4" label={{ value: "Média: 6,48 dias", fill: "#e05252", fontSize: 9, fontWeight: 400, position: "right" }} />
                <RechartsTooltip content={<DarkTooltip />} />
                <Bar dataKey="dias" fill="url(#barPurpleOC)" radius={[2, 2, 0, 0]} barSize={16}>
                  <LabelList dataKey="dias" position="top" fill="#d7dfeb" fontSize={8.5} fontWeight={400} formatter={(v) => fmt(v, 2)} />
                </Bar>
              </BarChart>
            </ResponsiveContainer>
          </div>
        </Panel>

        <Panel title="Produção Real por Variedade (Ton)" subtitle="Participação na produção total">
          <div className="grid h-[205px] grid-cols-[.9fr_1.15fr] items-center gap-2 px-3 pb-2">
            <ResponsiveContainer>
              <PieChart>
                <Pie data={variedadeData} dataKey="value" innerRadius="46%" outerRadius="86%" paddingAngle={1} stroke="#111927" strokeWidth={2}>
                  {variedadeData.map((_, i) => <Cell key={i} fill={pieColors[i]} />)}
                </Pie>
                <text x="50%" y="47%" textAnchor="middle" fill="#dde3f5" fontSize="17" fontWeight="600">204.829</text>
                <text x="50%" y="59%" textAnchor="middle" fill="#6f7d91" fontSize="8.5">Toneladas</text>
              </PieChart>
            </ResponsiveContainer>
            <div className="space-y-[7px] text-[10px]">
              {variedadeData.map((d, i) => (
                <div className="flex items-center gap-[5px]" key={d.name}>
                  <span className="h-[10px] w-[10px] rounded-[2px]" style={{ background: pieColors[i] }} />
                  <span className="w-[62px] text-[#8492b4]">{d.name}</span>
                  <span className="ml-auto text-right text-[#6f7d91]">{d.pct} ({fmt(d.value, 0)} t)</span>
                </div>
              ))}
            </div>
          </div>
        </Panel>

        <Panel title="ATR Médio por Variedade" subtitle="ATR médio e ATR/Ha real">
          <div className="h-[205px] px-3 pb-2">
            <ResponsiveContainer>
              <ComposedChart data={atrVarData} margin={{ top: 18, right: 8, left: -12, bottom: 0 }}>
                <defs><linearGradient id="barGreenAtr" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stopColor="#28b568" /><stop offset="1" stopColor="#137a43" /></linearGradient></defs>
                <CartesianGrid stroke={gridStroke} vertical={false} />
                <XAxis dataKey="variedade" tick={{ fill: softText, fontSize: 8.5, fontWeight: 400 }} axisLine={false} tickLine={false} />
                <YAxis yAxisId="left" domain={[100, 165]} tick={{ fill: softText, fontSize: 9, fontWeight: 400 }} axisLine={false} tickLine={false} label={{ value: "ATR", angle: -90, fill: softText, fontSize: 9, position: "insideLeft" }} />
                <YAxis yAxisId="right" orientation="right" domain={[0, 28000]} tickFormatter={(v) => (v ? `${Math.round(v / 1000) * 5}k` : "0")} tick={{ fill: softText, fontSize: 9, fontWeight: 400 }} axisLine={false} tickLine={false} label={{ value: "ATR/Ha (kg)", angle: 90, fill: softText, fontSize: 9, position: "insideRight" }} />
                <Legend iconSize={10} wrapperStyle={{ color: axisText, fontSize: 9.5, fontWeight: 400, top: -2 }} />
                <RechartsTooltip content={<DarkTooltip />} />
                <Bar yAxisId="left" dataKey="atr" name="ATR Médio" fill="url(#barGreenAtr)" radius={[2, 2, 0, 0]} barSize={20}>
                  <LabelList dataKey="atr" position="top" fill="#d7dfeb" fontSize={8.5} fontWeight={400} formatter={(v) => fmt(v, 1)} />
                </Bar>
                <Line yAxisId="right" dataKey="atrha" name="ATR/Ha Real" stroke="#f0c030" strokeWidth={2} dot={{ r: 4, fill: "#f0c030" }}>
                  <LabelList dataKey="atrha" position="top" fill="#d7dfeb" fontSize={8} fontWeight={400} formatter={(v) => fmt(v / 1000, 3)} />
                </Line>
              </ComposedChart>
            </ResponsiveContainer>
          </div>
        </Panel>
      </div>

      <div className="grid w-full gap-[7px] xl:grid-cols-3">
        <Panel title="ATR x TCH (Bolhas = Produção Real)" subtitle="Performance agronômica">
          <div className="relative h-[220px] px-3 pb-2">
            <div className="absolute left-10 top-3 z-10 text-[8px] font-medium leading-tight text-[#6e76f0]">Alto ATR<br />Baixo TCH</div>
            <div className="absolute right-6 top-3 z-10 text-right text-[8px] font-medium leading-tight text-[#22be5f]">Alto ATR<br />Alto TCH</div>
            <div className="absolute bottom-8 left-10 z-10 text-[8px] font-medium leading-tight text-[#d74b46]">Baixo ATR<br />Baixo TCH</div>
            <div className="absolute bottom-8 right-6 z-10 text-right text-[8px] font-medium leading-tight text-[#ebb22d]">Baixo ATR<br />Alto TCH</div>
            <ResponsiveContainer>
              <ScatterChart margin={{ top: 6, right: 6, left: -10, bottom: 0 }}>
                <CartesianGrid stroke={gridStroke} strokeDasharray="3 3" />
                <XAxis type="number" dataKey="x" domain={[38, 126]} tick={{ fill: softText, fontSize: 9, fontWeight: 400 }} axisLine={{ stroke: axisStroke }} tickLine={false} label={{ value: "TCH Real (T/Ha)", fill: softText, fontSize: 9, position: "insideBottom" }} />
                <YAxis type="number" dataKey="y" domain={[75, 200]} tick={{ fill: softText, fontSize: 9, fontWeight: 400 }} axisLine={{ stroke: axisStroke }} tickLine={false} label={{ value: "ATR Médio", angle: -90, fill: softText, fontSize: 9, position: "insideLeft" }} />
                <ZAxis dataKey="z" range={[26, 330]} />
                <ReferenceLine x={75} stroke="rgba(90,105,150,.45)" strokeDasharray="4 4" />
                <ReferenceLine y={127} stroke="rgba(90,105,150,.45)" strokeDasharray="4 4" />
                <RechartsTooltip content={<DarkTooltip />} />
                <Scatter data={scatterAtr} fillOpacity={0.76}>
                  {scatterAtr.map((entry, index) => <Cell key={index} fill={entry.c} stroke={entry.c} strokeOpacity={0.55} />)}
                </Scatter>
              </ScatterChart>
            </ResponsiveContainer>
          </div>
        </Panel>

        <Panel title="Idade (meses) x TCH Real" subtitle="Bolhas = Produção Real">
          <div className="h-[220px] px-3 pb-2">
            <ResponsiveContainer>
              <ScatterChart margin={{ top: 18, right: 6, left: -10, bottom: 0 }}>
                <CartesianGrid stroke={gridStroke} strokeDasharray="3 3" />
                <XAxis type="number" dataKey="x" domain={[5.5, 22.5]} ticks={[6,8,10,12,14,16,18,20,22]} tick={{ fill: softText, fontSize: 9, fontWeight: 400 }} axisLine={{ stroke: axisStroke }} tickLine={false} label={{ value: "Idade (meses)", fill: softText, fontSize: 9, position: "insideBottom" }} />
                <YAxis type="number" dataKey="y" domain={[38, 140]} tick={{ fill: softText, fontSize: 9, fontWeight: 400 }} axisLine={{ stroke: axisStroke }} tickLine={false} label={{ value: "TCH Real (T/Ha)", angle: -90, fill: softText, fontSize: 9, position: "insideLeft" }} />
                <ZAxis dataKey="z" range={[22, 250]} />
                <ReferenceLine x={11} stroke="rgba(55,210,110,.6)" strokeDasharray="5 4" label={{ value: "Idade ideal (~12 meses)", fill: "rgba(55,210,110,.85)", fontSize: 9, fontWeight: 400, position: "top" }} />
                <RechartsTooltip content={<DarkTooltip />} />
                <Scatter data={scatterIdade} fill="rgba(28,170,90,.68)" stroke="rgba(25,140,70,.45)" strokeOpacity={0.9} />
              </ScatterChart>
            </ResponsiveContainer>
          </div>
        </Panel>

        <Panel title="Heatmap de Performance por Fazenda" subtitle="Indicadores normalizados (Verde = melhor, Vermelho = pior)">
          <div className="px-3 pb-4 pt-1">
            <table className="w-full border-collapse text-[10.5px]">
              <thead>
                <tr className="border-b border-[#1e2540] text-[#8b97aa]">
                  <th className="py-[5px] text-left font-medium">Fazenda</th><th className="font-medium">TCH Real</th><th className="font-medium">ATR Médio</th><th className="font-medium">Gap TCH</th><th className="font-medium">Tempo Fech.</th><th className="font-medium">Índice Geral</th>
                </tr>
              </thead>
              <tbody>
                {heat.map((r, i) => (
                  <tr key={r.fazenda}>
                    <td className="border-b border-[#172030] py-[5px] text-left font-normal text-[#b9c5d5]">{r.fazenda}</td>
                    <HeatCell tone={i < 2 ? "g" : i < 4 ? "y" : "r"}>{fmt(r.real, 1)}</HeatCell>
                    <HeatCell tone={i < 3 ? "g" : i < 5 ? "y" : "r"}>{fmt(r.atr, 1)}</HeatCell>
                    <HeatCell tone={r.gapPct >= 2 ? "g" : r.gapPct >= 0 ? "y" : "r"}>{plus(r.gapPct, 1)}%</HeatCell>
                    <HeatCell tone={r.tempo < 6 ? "g" : r.tempo < 8 ? "y" : "r"}>{fmt(r.tempo, 2)}</HeatCell>
                    <HeatCell tone={r.indice > 80 ? "g" : r.indice > 55 ? "y" : "r"}>{r.indice}</HeatCell>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </Panel>
      </div>

      <div className="rounded-md border border-[#1d2e3e] bg-[#0b1622] px-4 py-2 text-[11px] font-normal text-[#8fa0b6]">
        Dados referentes às Ordens de Corte fechadas no período selecionado. Valores de TCH em toneladas por hectare. ATR em kg/tonelada.
      </div>
    </div>
  );
}
