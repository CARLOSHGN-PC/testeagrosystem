generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id             String         @id @default(cuid())
  name           String
  code           String         @unique
  cnpj           String?
  status         StatusAtivo    @default(ATIVO)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  plan           String         @default("basic")
  maxUsers       Int            @default(10)
  logoColor      String         @default("#55AB52")
  enabledModules Json?
  cutOrders      CutOrder[]
  estimates      Estimate[]
  farms          Farm[]
  fields         Field[]
  harvestPlans   HarvestPlan[]
  serviceOrders  ServiceOrder[]
  users          User[]
  varieties      Variety[]
}

model User {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  passwordHash String
  role         Role        @default(USER)
  status       StatusAtivo @default(ATIVO)
  companyId    String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  company      Company     @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model Farm {
  id        String     @id @default(cuid())
  companyId String
  code      String
  name      String
  area      Decimal?   @db.Decimal(12, 2)
  rawData   Json?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  cutOrders CutOrder[]
  estimates Estimate[]
  company   Company    @relation(fields: [companyId], references: [id])
  fields    Field[]

  @@unique([companyId, code])
  @@index([companyId])
}

model Field {
  id                 String              @id @default(cuid())
  companyId          String
  farmId             String?
  code               String
  name               String?
  area               Decimal?            @db.Decimal(12, 2)
  varietyId          String?
  stage              String?
  spacing            Decimal?            @db.Decimal(8, 2)
  plantingDate       DateTime?
  lastCutDate        DateTime?
  rawData            Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  cutOrderFields     CutOrderField[]
  estimates          Estimate[]
  company            Company             @relation(fields: [companyId], references: [id])
  farm               Farm?               @relation(fields: [farmId], references: [id])
  variety            Variety?            @relation(fields: [varietyId], references: [id])
  serviceOrderFields ServiceOrderField[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([farmId])
}

model Variety {
  id        String      @id @default(cuid())
  companyId String
  code      String?
  name      String
  status    StatusAtivo @default(ATIVO)
  rawData   Json?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  estimates Estimate[]
  fields    Field[]
  company   Company     @relation(fields: [companyId], references: [id])

  @@unique([companyId, name])
  @@index([companyId])
}

model Estimate {
  id           String            @id @default(cuid())
  companyId    String
  farmId       String?
  fieldId      String?
  varietyId    String?
  harvestYear  String?
  round        String?
  estimatedTch Decimal?          @db.Decimal(12, 2)
  estimatedTon Decimal?          @db.Decimal(14, 2)
  estimatedAtr Decimal?          @db.Decimal(12, 2)
  area         Decimal?          @db.Decimal(12, 2)
  source       String?
  rawData      Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  company      Company           @relation(fields: [companyId], references: [id])
  farm         Farm?             @relation(fields: [farmId], references: [id])
  field        Field?            @relation(fields: [fieldId], references: [id])
  variety      Variety?          @relation(fields: [varietyId], references: [id])
  history      EstimateHistory[]

  @@index([companyId])
  @@index([farmId])
  @@index([fieldId])
}

model EstimateHistory {
  id         String   @id @default(cuid())
  estimateId String
  action     String?
  oldData    Json?
  newData    Json?
  createdAt  DateTime @default(now())
  estimate   Estimate @relation(fields: [estimateId], references: [id])

  @@index([estimateId])
}

model HarvestPlan {
  id               String    @id @default(cuid())
  companyId        String
  harvestYear      String?
  front            String?
  sequence         Int?
  entryDate        DateTime?
  exitDate         DateTime?
  estimatedTon     Decimal?  @db.Decimal(14, 2)
  receivedBalance  Decimal?  @db.Decimal(14, 2)
  availableTotal   Decimal?  @db.Decimal(14, 2)
  dailyQuota       Decimal?  @db.Decimal(14, 2)
  remainingBalance Decimal?  @db.Decimal(14, 2)
  decimalDays      Decimal?  @db.Decimal(12, 4)
  integerDays      Int?
  rawData          Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  company          Company   @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([front])
  @@index([sequence])
}

model CutOrder {
  id          String          @id @default(cuid())
  companyId   String
  farmId      String?
  number      String?
  status      String?
  openingDate DateTime?
  closingDate DateTime?
  rawData     Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  company     Company         @relation(fields: [companyId], references: [id])
  farm        Farm?           @relation(fields: [farmId], references: [id])
  fields      CutOrderField[]

  @@index([companyId])
  @@index([farmId])
}

model CutOrderField {
  id           String   @id @default(cuid())
  cutOrderId   String
  fieldId      String?
  area         Decimal? @db.Decimal(12, 2)
  estimatedTon Decimal? @db.Decimal(14, 2)
  realTon      Decimal? @db.Decimal(14, 2)
  rawData      Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  cutOrder     CutOrder @relation(fields: [cutOrderId], references: [id])
  field        Field?   @relation(fields: [fieldId], references: [id])

  @@index([cutOrderId])
  @@index([fieldId])
}

model ServiceOrder {
  id          String              @id @default(cuid())
  companyId   String
  number      String?
  status      String?
  operation   String?
  openingDate DateTime?
  closingDate DateTime?
  rawData     Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  company     Company             @relation(fields: [companyId], references: [id])
  fields      ServiceOrderField[]

  @@index([companyId])
}

model ServiceOrderField {
  id             String       @id @default(cuid())
  serviceOrderId String
  fieldId        String?
  area           Decimal?     @db.Decimal(12, 2)
  rawData        Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  field          Field?       @relation(fields: [fieldId], references: [id])
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id])

  @@index([serviceOrderId])
  @@index([fieldId])
}

model AgriculturalProduction {
  id          String    @id @default(cuid())
  companyId   String
  farmCode    String?
  fieldCode   String?
  varietyName String?
  cutArea     Decimal?  @db.Decimal(12, 2)
  realTon     Decimal?  @db.Decimal(14, 2)
  realTch     Decimal?  @db.Decimal(12, 2)
  atr         Decimal?  @db.Decimal(12, 2)
  harvestDate DateTime?
  rawData     Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
  @@index([farmCode])
  @@index([fieldCode])
}

model Input {
  id        String      @id @default(cuid())
  companyId String
  code      String?
  name      String
  unit      String?
  status    StatusAtivo @default(ATIVO)
  rawData   Json?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model InputApplication {
  id              String    @id @default(cuid())
  companyId       String
  inputName       String?
  farmCode        String?
  fieldCode       String?
  operation       String?
  dose            Decimal?  @db.Decimal(12, 4)
  area            Decimal?  @db.Decimal(12, 2)
  applicationDate DateTime?
  rawData         Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([companyId])
}

model Protocol {
  id          String      @id @default(cuid())
  companyId   String
  name        String
  description String?
  status      StatusAtivo @default(ATIVO)
  rawData     Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([companyId])
}

model HarvestAssumption {
  id          String      @id
  companyId   String
  harvestYear String?
  name        String?
  status      StatusAtivo @default(ATIVO)
  dailyGoal   Decimal?    @db.Decimal(14, 2)
  weeklyGoal  Decimal?    @db.Decimal(14, 2)
  monthlyGoal Decimal?    @db.Decimal(14, 2)
  hourlyGoal  Decimal?    @db.Decimal(14, 2)
  rawData     Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([companyId])
}

model ClosureDashboardRecord {
  id               String    @id
  companyId        String
  harvestYear      String?
  farmCode         String?
  fieldCode        String?
  part             String?
  varietyName      String?
  stage            String?
  openingDate      DateTime?
  closingDate      DateTime?
  plantingDate     DateTime?
  releasedArea     Decimal?  @db.Decimal(12, 2)
  cutArea          Decimal?  @db.Decimal(12, 2)
  prevTon          Decimal?  @db.Decimal(14, 2)
  realTon          Decimal?  @db.Decimal(14, 2)
  prevTch          Decimal?  @db.Decimal(12, 2)
  realTch          Decimal?  @db.Decimal(12, 2)
  atr              Decimal?  @db.Decimal(12, 2)
  atrHaReal        Decimal?  @db.Decimal(14, 2)
  age              Decimal?  @db.Decimal(8, 2)
  cuts             Decimal?  @db.Decimal(8, 2)
  spacing          Decimal?  @db.Decimal(8, 2)
  dm               Int?
  timeDays         Decimal?  @db.Decimal(8, 2)
  variationPercent Decimal?  @db.Decimal(8, 2)
  rawData          Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([companyId])
  @@index([farmCode])
  @@index([fieldCode])
  @@index([closingDate])
}

model Operation {
  id             String      @id
  companyId      String
  code           String?
  name           String
  unit           String?
  type           String?
  costCenterCode String?
  costCenterName String?
  status         StatusAtivo @default(ATIVO)
  rawData        Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([companyId])
  @@index([code])
}

model Professional {
  id           String   @id
  companyId    String
  name         String
  cpf          String?
  phone        String?
  registration String?
  role         String?
  team         String?
  unit         String?
  notes        String?
  status       String?
  rawData      Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
  @@index([cpf])
  @@index([registration])
}

model PlanningTreatment {
  id                 String   @id
  companyId          String
  harvestYear        String?
  sequential         Int?
  status             String?
  operation          Json?
  protocolOriginalId String?
  protocolName       String?
  subProtocol        String?
  editedProtocol     Json?
  originalCost       Decimal? @db.Decimal(14, 2)
  plannedCost        Decimal? @db.Decimal(14, 2)
  justification      String?
  totalFields        Int?
  totalFarms         Int?
  farms              Json?
  rawData            Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([companyId])
  @@index([harvestYear])
  @@index([status])
  @@index([companyId, harvestYear])
}

model PlanningTreatmentField {
  id                  String   @id
  planningTreatmentId String
  companyId           String
  harvestYear         String?
  fieldCode           String?
  fieldName           String?
  farmCode            String?
  farmName            String?
  cut                 String?
  area                Decimal? @db.Decimal(12, 2)
  status              String?
  rawData             Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([planningTreatmentId])
  @@index([companyId])
  @@index([harvestYear])
  @@index([fieldCode])
  @@index([companyId, harvestYear])
  @@index([companyId, harvestYear, fieldCode])
}

model DashboardColheitaRegistro {
  id               String    @id
  companyId        String    @map("company_id")
  companyCode      String?   @map("codigo_empresa")
  harvestYear      String?   @map("safra")
  date             DateTime? @map("data")
  time             String?   @map("hora")
  dateTime         DateTime? @map("data_hora")
  front            String?   @map("frente")
  description      String?   @map("descricao")
  delivery         Decimal?  @map("entrega") @db.Decimal(14, 4)
  densityAverage   Decimal?  @map("densidade_media") @db.Decimal(14, 4)
  targetPeriod     Decimal?  @map("meta_periodo") @db.Decimal(14, 4)
  deliveredPercent Decimal?  @map("entregue_percentual") @db.Decimal(14, 4)
  deliveryAverage  Decimal?  @map("media_entrega") @db.Decimal(14, 4)
  targetAverage    Decimal?  @map("media_meta") @db.Decimal(14, 4)
  difference       Decimal?  @map("diferenca") @db.Decimal(14, 4)
  importedBy       String?   @map("importado_por")
  importedAt       DateTime? @map("importado_em")
  rawData          Json?     @map("dados_originais")
  createdAt        DateTime  @default(now()) @map("criado_em")
  updatedAt        DateTime  @updatedAt @map("atualizado_em")

  @@index([companyId])
  @@index([companyCode])
  @@index([harvestYear])
  @@index([date])
  @@index([front])
  @@index([companyId, harvestYear])
  @@index([companyCode, harvestYear])
  @@map("dashboard_colheita_registros")
}

model DashboardColheitaOperacional {
  id           String   @id
  companyId    String   @map("company_id")
  companyCode  String?  @map("codigo_empresa")
  type         String?  @map("tipo")
  millRotation Decimal? @map("rotacao_moenda") @db.Decimal(14, 4)
  cartStock    Decimal? @map("estoque_carretas") @db.Decimal(14, 4)
  rawData      Json?    @map("dados_originais")
  createdAt    DateTime @default(now()) @map("criado_em")
  updatedAt    DateTime @updatedAt @map("atualizado_em")

  @@index([companyId])
  @@index([companyCode])
  @@map("dashboard_colheita_operacional")
}

model DashboardColheitaAtrFazenda {
  id          String    @id
  companyId   String    @map("company_id")
  companyCode String?   @map("codigo_empresa")
  harvestYear String?   @map("safra")
  date        DateTime? @map("data")
  farmCode    String?   @map("codigo_fazenda")
  farmName    String?   @map("nome_fazenda")
  farmLabel   String?   @map("fazenda")
  supplier    String?   @map("fornecedor")
  property    String?   @map("propriedade")
  name        String?   @map("nome")
  atr         Decimal?  @db.Decimal(14, 4)
  importedBy  String?   @map("importado_por")
  importedAt  DateTime? @map("importado_em")
  rawData     Json?     @map("dados_originais")
  createdAt   DateTime  @default(now()) @map("criado_em")
  updatedAt   DateTime  @updatedAt @map("atualizado_em")

  @@index([companyId])
  @@index([companyCode])
  @@index([harvestYear])
  @@index([date])
  @@index([farmCode])
  @@index([companyId, harvestYear])
  @@index([companyCode, harvestYear])
  @@map("dashboard_colheita_atr_fazenda")
}

model DashboardColheitaAtrMensal {
  id          String    @id
  companyId   String    @map("company_id")
  companyCode String?   @map("codigo_empresa")
  harvestYear String?   @map("safra")
  date        DateTime? @map("data")
  atr         Decimal?  @db.Decimal(14, 4)
  accumulated Decimal?  @map("acumulado") @db.Decimal(14, 4)
  importedBy  String?   @map("importado_por")
  importedAt  DateTime? @map("importado_em")
  rawData     Json?     @map("dados_originais")
  createdAt   DateTime  @default(now()) @map("criado_em")
  updatedAt   DateTime  @updatedAt @map("atualizado_em")

  @@index([companyId])
  @@index([companyCode])
  @@index([harvestYear])
  @@index([date])
  @@index([companyId, harvestYear])
  @@index([companyCode, harvestYear])
  @@map("dashboard_colheita_atr_mensal")
}

model DashboardColheitaImpureza {
  id          String    @id
  companyId   String    @map("company_id")
  companyCode String?   @map("codigo_empresa")
  harvestYear String?   @map("safra")
  date        DateTime? @map("data")
  time        String?   @map("hora")
  dateTime    DateTime? @map("data_hora")
  mineral     Decimal?  @map("impureza_mineral") @db.Decimal(14, 4)
  vegetal     Decimal?  @map("impureza_vegetal") @db.Decimal(14, 4)
  importedBy  String?   @map("importado_por")
  importedAt  DateTime? @map("importado_em")
  rawData     Json?     @map("dados_originais")
  createdAt   DateTime  @default(now()) @map("criado_em")
  updatedAt   DateTime  @updatedAt @map("atualizado_em")

  @@index([companyId])
  @@index([companyCode])
  @@index([harvestYear])
  @@index([date])
  @@index([companyId, harvestYear])
  @@index([companyCode, harvestYear])
  @@map("dashboard_colheita_impurezas")
}

model DashboardColheitaImpurezaMineralTurno {
  id          String    @id
  companyId   String    @map("company_id")
  companyCode String?   @map("codigo_empresa")
  harvestYear String?   @map("safra")
  date        DateTime? @map("data")
  front       String?   @map("frente")
  frontLabel  String?   @map("frente_label")
  shiftA      Decimal?  @map("turno_a") @db.Decimal(14, 4)
  shiftB      Decimal?  @map("turno_b") @db.Decimal(14, 4)
  shiftC      Decimal?  @map("turno_c") @db.Decimal(14, 4)
  rawData     Json?     @map("dados_originais")
  createdAt   DateTime  @default(now()) @map("criado_em")
  updatedAt   DateTime  @updatedAt @map("atualizado_em")

  @@index([companyId])
  @@index([companyCode])
  @@index([harvestYear])
  @@index([date])
  @@index([front])
  @@index([companyId, harvestYear])
  @@index([companyCode, harvestYear])
  @@map("dashboard_colheita_impureza_mineral_turno")
}

model DashboardColheitaImpurezaVegetalTurno {
  id          String    @id
  companyId   String    @map("company_id")
  companyCode String?   @map("codigo_empresa")
  harvestYear String?   @map("safra")
  date        DateTime? @map("data")
  front       String?   @map("frente")
  frontLabel  String?   @map("frente_label")
  shiftA      Decimal?  @map("turno_a") @db.Decimal(14, 4)
  shiftB      Decimal?  @map("turno_b") @db.Decimal(14, 4)
  shiftC      Decimal?  @map("turno_c") @db.Decimal(14, 4)
  rawData     Json?     @map("dados_originais")
  createdAt   DateTime  @default(now()) @map("criado_em")
  updatedAt   DateTime  @updatedAt @map("atualizado_em")

  @@index([companyId])
  @@index([companyCode])
  @@index([harvestYear])
  @@index([date])
  @@index([front])
  @@index([companyId, harvestYear])
  @@index([companyCode, harvestYear])
  @@map("dashboard_colheita_impureza_vegetal_turno")
}

model DashboardColheitaParada {
  id          String    @id
  companyId   String    @map("company_id")
  companyCode String?   @map("codigo_empresa")
  date        DateTime? @map("data")
  type        String?   @map("tipo")
  startTime   String?   @map("hora_inicio")
  endTime     String?   @map("hora_fim")
  observation String?   @map("observacao")
  rawData     Json?     @map("dados_originais")
  createdAt   DateTime  @default(now()) @map("criado_em")
  updatedAt   DateTime  @updatedAt @map("atualizado_em")

  @@index([companyId])
  @@index([companyCode])
  @@index([date])
  @@index([type])
  @@map("dashboard_colheita_paradas")
}

model DashboardColheitaPremissa {
  id                String   @id
  companyId         String   @map("company_id")
  companyCode       String?  @map("codigo_empresa")
  projectedCrushing Decimal? @map("moagem_prevista") @db.Decimal(16, 4)
  reprojectedGoal   Decimal? @map("meta_reprojetada") @db.Decimal(16, 4)
  dayGoal           Decimal? @map("meta_dia") @db.Decimal(16, 4)
  weekGoal          Decimal? @map("meta_semana") @db.Decimal(16, 4)
  monthGoal         Decimal? @map("meta_mes") @db.Decimal(16, 4)
  hourGoal          Decimal? @map("meta_hora") @db.Decimal(16, 4)
  atr               Decimal? @db.Decimal(14, 4)
  tah               Decimal? @db.Decimal(14, 4)
  tch               Decimal? @db.Decimal(14, 4)
  broca             Decimal? @db.Decimal(14, 4)
  vegetalImpurity   Decimal? @map("impureza_vegetal") @db.Decimal(14, 4)
  mineralImpurity   Decimal? @map("impureza_mineral") @db.Decimal(14, 4)
  monthlyGoals      Json?    @map("metas_mensais")
  rawData           Json?    @map("dados_originais")
  createdAt         DateTime @default(now()) @map("criado_em")
  updatedAt         DateTime @updatedAt @map("atualizado_em")

  @@index([companyId])
  @@index([companyCode])
  @@map("dashboard_colheita_premissas")
}

enum Role {
  ADMIN
  MANAGER
  USER
}

enum StatusAtivo {
  ATIVO
  INATIVO
}
